{
  "name": "it-support-saas",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-tenant IT support SaaS: ticketing, support portal/widget, admin dashboard, and a per-tenant AI support agent (RAG + human escalation).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:isolation": "vitest run tests/isolation",
    "db:types": "echo \"Use the Supabase MCP/CLI to regenerate src/types/database.ts\"",
    "eval": "echo \"TODO: run AI eval harness (Phase 5)\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.1.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^16.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^9.1.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
