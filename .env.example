# Copy to .env.local and fill in. NEVER commit real values.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — use ONLY in trusted backend/job code. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers (server-only) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3
VOYAGE_EMBED_DIM=1024

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for the Vercel Cron job worker (/api/jobs/process). Vercel sends it as
# a Bearer token; the route fails closed if unset. Generate a long random value.
CRON_SECRET=
